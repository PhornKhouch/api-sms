# ── Local development ──────────────────────────────────────────
# Used when MYSQL_URL / DATABASE_URL is NOT set.
DB_NAME=backend6_project
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# ── Railway (production) ───────────────────────────────────────
# When you add the MySQL plugin, Railway auto-injects MYSQL_URL.
# You normally do NOT set this by hand — reference it in Variables:
#   MYSQL_URL = ${{ MySQL.MYSQL_URL }}
# MYSQL_URL=mysql://user:password@host:port/database

# PORT is injected automatically by Railway. Leave unset locally (defaults to 3000).
# PORT=3000

# Optional: set to "alter" or "force" to change how sequelize.sync() runs.
# DB_SYNC=
